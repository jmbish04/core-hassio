---
import BaseLayout from '../layouts/BaseLayout.astro';
import { EnergyChart } from '../components/Dashboard/EnergyChart';
import { AssistantChat } from '../components/Chat/AssistantChat';
import { LightToggle } from '../components/HAWebSocketClient';
---

<BaseLayout title="Smart Home Dashboard" description="Control your smart home">
  <main class="container mx-auto py-8 px-4">
    <div class="mb-8 flex items-center justify-between">
      <h1 class="text-3xl font-bold tracking-tight">Smart Home</h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
      <!-- Controls -->
      <section class="flex flex-col gap-4">
        <h2 class="text-2xl font-semibold">Controls</h2>
        <div class="p-6 border rounded-lg bg-card text-card-foreground shadow-sm">
          <h3 class="font-medium mb-4">Living Room Light</h3>
          <LightToggle entityId="light.living_room" client:load />
        </div>
        <div class="p-6 border rounded-lg bg-card text-card-foreground shadow-sm">
          <h3 class="font-medium mb-4">Bedroom Light</h3>
          <LightToggle entityId="light.bedroom" client:load />
        </div>
      </section>

      <!-- Analytics -->
      <section class="flex flex-col gap-4">
        <h2 class="text-2xl font-semibold">Analytics</h2>
        <EnergyChart client:load />
      </section>
    </div>

    <!-- AI Assistant -->
    <section class="mt-12">
      <h2 class="text-2xl font-semibold mb-4">AI Home Assistant</h2>
      <AssistantChat client:load />
    </section>
  </main>
</BaseLayout>
